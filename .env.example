# ===============================================================================
# 🏷️ AISaleAnalyst - Environment Configuration Example
# Copy this file to '.env' and fill in your API keys and preferred settings.
# ===============================================================================

# ===============================================================================
# 🔑 API KEYS & PROVIDERS
# ===============================================================================
# OpenAI API Key (required if using GPT-4o for vision analysis & deduplication)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (optional alternative to OpenAI for Gemini 2.5 Flash)
# GEMINI_API_KEY=your_gemini_api_key_here

# 2Captcha API Key & Toggle (set USE_2CAPTCHA=false to solve CAPTCHA manually in browser)
TWOCAPTCHA_API_KEY=your_2captcha_key_here
USE_2CAPTCHA=true

# ===============================================================================
# 📦 SHIPPING (SHIPPO)
# ===============================================================================
# Shippo API key — create a free account at goshippo.com > Settings > API
SHIPPO_API_KEY=your_shippo_api_key_here

# Origin ZIP code — where YOU ship packages FROM
SHIP_FROM_ZIP=60601

# Destination ZIP code — used for rate estimation (60601 = Chicago, central US avg)
SHIP_TO_ZIP=10001

# Preferred carrier service for the shipping cost shown in the report:
#   cheapest      → always pick the lowest-cost option across all carriers (recommended)
#   usps_ground   → USPS Ground Advantage
#   usps_priority → USPS Priority Mail
#   ups_ground    → UPS Ground
SHIP_SERVICE=cheapest

# Set to true to use fixed manual dimensions instead of AI-estimated ones
SHIP_MANUAL_DIMS=false

# Manual fallback dimensions — only used when SHIP_MANUAL_DIMS=true
SHIP_MANUAL_LENGTH=12
SHIP_MANUAL_WIDTH=10
SHIP_MANUAL_HEIGHT=8
SHIP_MANUAL_WEIGHT=3

# ===============================================================================
# ⚙️ APPLICATION RUNTIME CONFIGURATION
# ===============================================================================
# Maximum number of images to analyze per run (e.g., 10, 50, 100)
MAX_IMAGES=10000

# Path to local images folder (leave blank to prompt for estate sale URL at runtime)
IMAGES_FOLDER=

# Output file path for the generated HTML report
OUTPUT_HTML=./demo_report.html

# ===============================================================================
# ⚡ CONCURRENCY & WORKER THREADS
# ===============================================================================
# Parallel worker threads for AI vision analysis (default: 8)
VISION_WORKERS=8

# Parallel worker threads for eBay sold-comps HTTP scraping (default: 8)
EBAY_WORKERS=8

# Seconds delay between eBay HTTP requests to prevent rate-limiting (default: 1.0)
EBAY_DELAY=1.0

# ===============================================================================
# 🔍 DEDUPLICATION & VALUATION SETTINGS
# ===============================================================================
# Enable deduplication (true / false). Set to false to completely bypass all deduplication.
USE_DEDUP=true


# Enable Stage 2 AI deduplication pass (true / false)
USE_AI_DEDUP=true

# ===============================================================================
# 📊 REPORT DISPLAY & SORTING
# ===============================================================================
# Primary report sorting column: "roi" | "profit" | "median" | "confidence"
SORT_BY=roi

# Maximum top opportunities shown in summary section (default: 20)
TOP_N=20
